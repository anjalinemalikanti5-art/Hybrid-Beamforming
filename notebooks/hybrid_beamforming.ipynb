# notebooks/hybrid_beamforming.ipynb

import os
import numpy as np
import pandas as pd
import matplotlib.pyplot as plt
from scipy.linalg import pinv
from scipy.signal import savgol_filter

# =========================
# Parameters
# =========================
PI = np.pi
EPS = 1e-12

# Create plots folder if it doesn't exist
os.makedirs("../plots", exist_ok=True)

# =========================
# 1. Read CSV
# =========================
data_file = "../dataset/C_44_train_converted.csv"  # adjust path
raw = pd.read_csv(data_file, header=None).values
M, N = raw.shape
print(f"Antennas = {M}, Snapshots = {N}")

# Convert to complex
X = raw.astype(np.complex128)

# =========================
# 2. DOA Denoising (Savitzky–Golay)
# =========================
theta_noisy = np.linspace(25, 35, N)
theta_hat = savgol_filter(theta_noisy, window_length=5, polyorder=2)

# =========================
# 3. Machine Learning Linear DOA Prediction
# =========================
X_index = np.arange(N)
beta = np.cov(X_index, theta_noisy)[0,1] / np.var(X_index)
alpha = theta_noisy.mean() - beta * X_index.mean()
theta_ml = alpha + beta * X_index

# Save ML predictions
pd.DataFrame({'Index': X_index, 'Theta_ML': theta_ml}).to_csv("../dataset/ml_doa_pred.csv", index=False)

# =========================
# 4. Covariance Matrix & Inversion
# =========================
R = X @ X.conj().T / N
Rinv = pinv(R)

# =========================
# 5. Steering Vector & Beamformers
# =========================
def steering_vector(theta_deg, M):
    theta = theta_deg * PI / 180
    return np.exp(1j * PI * np.arange(M) * np.sin(theta))

a_s = steering_vector(theta_ml.mean(), M)
w_ml = a_s / np.linalg.norm(a_s)
w_mvdr = (Rinv @ a_s) / (a_s.conj().T @ Rinv @ a_s)

# =========================
# 6. Hybrid Beamforming Optimization
# =========================
X_sig = np.outer(a_s, a_s.conj().T @ X)
best_snr = -1e9
best_alpha = 0.0
for alpha in np.arange(0, 1.01, 0.01):
    w_tmp = (alpha * w_ml + (1-alpha) * w_mvdr)
    w_tmp /= np.linalg.norm(w_tmp)
    y_tmp = w_tmp.conj().T @ X
    y_sig = w_tmp.conj().T @ X_sig
    y_n = y_tmp - y_sig
    Ps = np.mean(np.abs(y_sig)**2)
    Pn = max(EPS, np.mean(np.abs(y_n)**2))
    snr = 10 * np.log10(Ps / Pn)
    if snr > best_snr:
        best_snr = snr
        best_alpha = alpha

w_hybrid = (best_alpha*w_ml + (1-best_alpha)*w_mvdr)
w_hybrid /= np.linalg.norm(w_hybrid)

# =========================
# 7. Compute SNRs
# =========================
s_raw = X[0,:]
Ps_in = np.mean(np.abs(s_raw)**2)
Pn_in = np.mean(np.abs(s_raw - X_sig[0,:])**2)
snr_in = 10*np.log10(Ps_in / max(EPS,Pn_in))

y_ml = w_ml.conj().T @ X
y_ml_sig = w_ml.conj().T @ X_sig
snr_ml = 10*np.log10(np.mean(np.abs(y_ml_sig)**2) / max(EPS, np.mean(np.abs(y_ml - y_ml_sig)**2)))

y_mv = w_mvdr.conj().T @ X
y_mv_sig = w_mvdr.conj().T @ X_sig
snr_mvdr = 10*np.log10(np.mean(np.abs(y_mv_sig)**2) / max(EPS, np.mean(np.abs(y_mv - y_mv_sig)**2)))

y_hyb = w_hybrid.conj().T @ X
y_hyb_sig = w_hybrid.conj().T @ X_sig
snr_hybrid = 10*np.log10(np.mean(np.abs(y_hyb_sig)**2) / max(EPS, np.mean(np.abs(y_hyb - y_hyb_sig)**2)))

print(f"\nSNR Comparison (dB):\nInput: {snr_in:.2f}\nML: {snr_ml:.2f}\nMVDR: {snr_mvdr:.2f}\nHybrid: {snr_hybrid:.2f}")
print(f"Improvement: {snr_hybrid-snr_in:.2f} dB")

# =========================
# 8. Plot DOA Estimation
# =========================
plt.figure(figsize=(8,4))
plt.plot(theta_noisy, label='Noisy')
plt.plot(theta_hat, label='Denoised')
plt.plot(theta_ml, label='ML Prediction')
plt.xlabel("Snapshot")
plt.ylabel("Angle (deg)")
plt.title("DOA Estimation")
plt.legend()
plt.grid(True)
plt.savefig("../plots/doa_estimation.png", dpi=300)
plt.show()

# =========================
# 9. Beam Patterns
# =========================
angles = np.arange(-90, 91)
beam_ml = [20*np.log10(np.abs(w_ml.conj().T @ steering_vector(a, M))) for a in angles]
beam_mvdr = [20*np.log10(np.abs(w_mvdr.conj().T @ steering_vector(a, M))) for a in angles]
beam_hyb = [20*np.log10(np.abs(w_hybrid.conj().T @ steering_vector(a, M))) for a in angles]

plt.figure(figsize=(8,4))
plt.plot(angles, beam_ml, label='ML')
plt.plot(angles, beam_mvdr, label='MVDR')
plt.plot(angles, beam_hyb, label='Hybrid')
plt.xlabel("Angle (deg)")
plt.ylabel("Magnitude (dB)")
plt.title("Beam Patterns")
plt.legend()
plt.grid(True)
plt.savefig("../plots/beam_patterns.png", dpi=300)
plt.show()

# =========================
# 10. Save SNR Comparison
# =========================
snr_comparison = pd.DataFrame({
    "Type": ["Input", "ML", "MVDR", "Hybrid"],
    "SNR_dB": [snr_in, snr_ml, snr_mvdr, snr_hybrid]
})
snr_comparison.to_csv("../plots/snr_comparison.csv", index=False)
